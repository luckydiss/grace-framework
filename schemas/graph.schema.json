{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GRACE Graph Export",
  "type": "object",
  "required": ["modules", "contracts", "anchors", "beliefs", "edges"],
  "properties": {
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "contract_path"],
        "properties": {
          "id": {
            "type": "string"
          },
          "contract_path": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "module_id", "kind", "has_belief_state"],
        "properties": {
          "id": {
            "type": "string"
          },
          "module_id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "has_belief_state": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "beliefs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "source", "target"],
        "properties": {
          "type": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
